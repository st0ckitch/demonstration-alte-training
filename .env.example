# Copy this file to .env and fill in what you need. Never commit .env.

# OPTIONAL: a server-side Anthropic key. If set, the chat works without pasting
# a key in the browser. Leave it blank to require each user to paste their own
# key in the UI (the "API key" button) — that key is sent per-request and never
# stored on the server.
ANTHROPIC_API_KEY=

# Optional overrides
MEDILEAD_PORT=3200

# Model used by the concierge and the follow-up drafter.
#   claude-opus-4-8   (default) — strongest reasoning
#   claude-sonnet-4-6           — faster / cheaper
MEDILEAD_MODEL=claude-opus-4-8

# Optional HTTP Basic auth gate for the whole site (demo protection).
# MEDILEAD_USER=medilead
# MEDILEAD_PASSWORD=
